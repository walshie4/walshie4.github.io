---
import Layout from '../layouts/Layout.astro';
---

<Layout title="adam.walsh">
  <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 380px; text-align: center; gap: 30px; padding: 20px 0;">
    
    <!-- Fallback avatar with animated scanlines -->
    <div class="avatar-container" style="width: 80px; height: 80px; border-radius: 50%; border: 2px solid var(--matrix-green); overflow: hidden; position: relative; display: flex; justify-content: center; align-items: center; background: #001100; box-shadow: 0 0 20px rgba(0, 255, 0, 0.25);">
      <div class="avatar-matrix-code" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(180deg, transparent 0%, rgba(0,255,0,0.15) 50%, transparent 100%); animation: scanLines 2.5s linear infinite;"></div>
      <div class="avatar-fallback" style="font-size: 1.8em; font-weight: bold; color: var(--matrix-green); text-shadow: 0 0 10px var(--matrix-glow); z-index: 2; font-family: var(--mono);">AW</div>
    </div>

    <!-- Glitch Name Header -->
    <div class="identity-info" style="margin-top: -10px;">
      <h1 class="glitch-text" data-text="Adam Walsh" style="margin: 0; font-size: 2.8rem; font-weight: 700; color: var(--matrix-green); font-family: var(--mono); text-transform: uppercase; letter-spacing: 2px;">Adam Walsh</h1>
    </div>

    <!-- Minimal Secure Links grid (fits beautifully in a centered row/grid) -->
    <div class="cyber-link-container" style="width: 100%; max-width: 500px; margin-top: 5px;">
      <div class="grid-links">
        <a href="https://github.com/walshie4" target="_blank" class="cyber-link">
          <svg viewBox="0 0 16 16" style="width: 18px; height: 18px; fill: currentColor; margin-right: 12px;" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
          <span class="label">GitHub</span>
          <span class="arrow">&gt;</span>
        </a>
        <a href="https://www.linkedin.com/in/awalsh4/" target="_blank" class="cyber-link">
          <svg viewBox="0 0 24 24" style="width: 18px; height: 18px; fill: currentColor; margin-right: 12px;" aria-hidden="true">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
          </svg>
          <span class="label">LinkedIn</span>
          <span class="arrow">&gt;</span>
        </a>
        <a href="https://medium.com/@_walshie_" target="_blank" class="cyber-link">
          <svg viewBox="0 0 24 24" style="width: 18px; height: 18px; fill: currentColor; margin-right: 12px;" aria-hidden="true">
            <path d="M13 12c0 3.314-2.91 6-6.5 6S0 15.314 0 12s2.91-6 6.5-6 6.5 2.686 6.5 6zm7.5 0c0 3.148-.84 5.7-1.875 5.7S16.75 15.148 16.75 12s.84-5.7 1.875-5.7 1.875 2.552 1.875 5.7zm3.5 0c0 2.65-.246 4.8-.55 4.8s-.55-2.15-.55-4.8.246-4.8.55-4.8.55 2.15.55 4.8z" />
          </svg>
          <span class="label">Medium</span>
          <span class="arrow">&gt;</span>
        </a>
      </div>
    </div>
  </div>
</Layout>
