---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Adam Walsh" minimal>
  <div style="display: flex; flex-direction: column; align-items: center; gap: 18px; text-align: center;">

    <!-- Name -->
    <h1 class="glitch-text" data-text="Adam Walsh"
      style="margin: 0; font-size: 1.4rem; font-weight: 400; color: var(--matrix-green);
             font-family: var(--mono); text-transform: uppercase; letter-spacing: 4px;">
      Adam Walsh
    </h1>

    <!-- Links -->
    <div style="display: flex; gap: 24px; align-items: center;">
      <a href="https://github.com/walshie4" target="_blank"
        style="color: var(--muted); font-family: var(--mono); font-size: 0.75rem;
               text-decoration: none; letter-spacing: 2px; text-transform: uppercase;
               transition: color 0.2s ease;">
        GitHub
      </a>
      <span style="color: var(--border);">/</span>
      <a href="https://www.linkedin.com/in/awalsh4/" target="_blank"
        style="color: var(--muted); font-family: var(--mono); font-size: 0.75rem;
               text-decoration: none; letter-spacing: 2px; text-transform: uppercase;
               transition: color 0.2s ease;">
        LinkedIn
      </a>
      <span style="color: var(--border);">/</span>
      <a href="https://medium.com/@_walshie_" target="_blank"
        style="color: var(--muted); font-family: var(--mono); font-size: 0.75rem;
               text-decoration: none; letter-spacing: 2px; text-transform: uppercase;
               transition: color 0.2s ease;">
        Medium
      </a>
    </div>
  </div>
</Layout>

<style>
  a:hover {
    color: var(--matrix-green) !important;
  }
</style>
