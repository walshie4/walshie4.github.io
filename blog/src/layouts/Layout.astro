---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  minimal?: boolean;
}

const { title, description = 'Personal blog by Adam Walsh.', minimal = false } = Astro.props;
const siteTitle = 'Adam Walsh';

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';
const isBlog = currentPath.startsWith('/blog');
const isAbout = currentPath.startsWith('/about');
const isPrivate = currentPath.startsWith('/private');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title === siteTitle ? siteTitle : `${title} — ${siteTitle}`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Matrix Rain Background Canvas -->
    <canvas id="matrix-canvas"></canvas>

    <!-- Translucent Background Dimmer -->
    <div id="background-dimmer"></div>

    <!-- Intro Gate Removed -->

    <!-- Overlay Alerts for Matrix Dance -->
    <div id="dance-overlay" class="hidden">
      <div class="overlay-content">
        <div id="overlay-text" class="glitch-text" data-text=""></div>
        <div id="overlay-subtext"></div>
      </div>
    </div>

    {minimal ? (
      <!-- Minimal overlay: name + links directly on matrix -->
      <div class="minimal-overlay">
        <slot />
      </div>
    ) : (
      <!-- Full Terminal Container -->
      <div class="terminal-container">
        <header class="terminal-header">
          <div class="terminal-buttons">
            <span class="btn close"></span>
            <span class="btn minimize"></span>
            <span class="btn maximize"></span>
          </div>
          <div class="terminal-title">system_connection@walshie4.io: ~</div>
        </header>

        <div class="terminal-body">
          <nav class="terminal-nav">
            <a href="/" class={`nav-link-btn ${isHome ? 'active' : ''}`}>/identity</a>
            <a href="/blog" class={`nav-link-btn ${isBlog ? 'active' : ''}`}>/logs</a>
            <a href="/about" class={`nav-link-btn ${isAbout ? 'active' : ''}`}>/about</a>
            <a href="/private" class={`nav-link-btn ${isPrivate ? 'active' : ''}`}>/private</a>
          </nav>

          <main class="article-body">
            <slot />
          </main>

          <div class="interactive-hint">
            <span class="blink">&gt;&gt;&gt;</span> Click canvas for a code ripple. Type secret phrases ("red pill", "blue pill", "white rabbit", "there is no spoon", "neo") to alter the construct.
          </div>
        </div>

        <footer class="terminal-footer">
          <div class="status-indicator">
            <span class="dot pulse"></span> SECURE CONNECTION ESTABLISHED
          </div>
          <div class="copyright">
            &copy; {new Date().getFullYear()} WALSHIE4 &mdash; MADE WITH TOO MUCH COFFEE
          </div>
        </footer>
      </div>
    )}

    <!-- Matrix Canvas rain interaction script -->
    <script>
      function startMatrixConstruct() {
        // ---------------------------------------------------------------------
        // 1. Decrypted State Initialization (Intro Gate Removed)
        // ---------------------------------------------------------------------
        const isDecrypted = true;
        document.body.classList.add('decrypted');

        // ---------------------------------------------------------------------
        // 2. Matrix Digital Rain Canvas
        // ---------------------------------------------------------------------
        const canvas = document.getElementById('matrix-canvas') as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        function getWidth() {
          return window.innerWidth || document.documentElement.clientWidth || document.body.clientWidth || 1024;
        }
        function getHeight() {
          return window.innerHeight || document.documentElement.clientHeight || document.body.clientHeight || 768;
        }

        let width = (canvas.width = getWidth());
        let height = (canvas.height = getHeight());

        window.addEventListener('resize', () => {
          width = canvas.width = getWidth();
          height = canvas.height = getHeight();
          initializeColumns();
        });

        const fontHeight = 16;
        ctx.font = `${fontHeight}px monospace`;

        const chars = "ｦｧｨｩｪｫｬｭｮｯｰｱｲｳｴｵｶｷｸｹｺｻｼｽｾｿﾀﾁﾂﾃﾄﾅﾆﾇﾈﾉﾊﾋﾌﾍﾎﾏﾐﾑﾒﾓﾔﾕﾖﾗﾘﾙﾚﾛﾜﾝ1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZ$+-*/=<>[]{}#&@_".split("");

        let columns: Drop[] = [];
        
        let colorMode = 'green'; // 'green', 'red', 'blue', 'gold'
        let bulletTime = false;
        let warpEffect = false;
        let zionFrenzy = false;
        let timeScale = 1.0;
        
        let ripples: any[] = [];
        let mouse = { x: -9999, y: -9999, lastActive: 0 };

        class Drop {
          x: number;
          y!: number;
          speed!: number;
          length!: number;
          chars!: string[];
          glows!: boolean[];
          mutationRate!: number;
          opacity!: number;

          constructor(x: number) {
            this.x = x;
            this.reset();
            this.y = Math.random() * -100 - 20;
          }

          reset() {
            this.y = Math.random() * -20 - 20;
            this.speed = Math.random() * 2 + 1.5;
            this.length = Math.floor(Math.random() * 18) + 8;
            this.chars = [];
            this.glows = [];
            
            for (let i = 0; i < this.length; i++) {
              this.chars.push(chars[Math.floor(Math.random() * chars.length)]);
              this.glows.push(Math.random() < 0.15);
            }
            this.mutationRate = Math.random() * 0.05 + 0.01;
            this.opacity = Math.random() * 0.4 + 0.6;
          }

          update() {
            let speedFactor = timeScale;
            if (bulletTime) speedFactor = 0.12;
            if (zionFrenzy) speedFactor = 3.5;

            const dx = this.x - mouse.x;
            if (Math.abs(dx) < 60 && Date.now() - mouse.lastActive < 2000) {
              speedFactor *= 1.8;
            }

            this.y += this.speed * speedFactor;

            for (let i = 0; i < this.length; i++) {
              if (Math.random() < this.mutationRate) {
                this.chars[i] = chars[Math.floor(Math.random() * chars.length)];
              }
            }

            if (this.y - (this.length * fontHeight) > height) {
              this.reset();
            }
          }

          draw() {
            const startY = Math.floor(this.y);
            const gridX = Math.floor(this.x);

            for (let i = 0; i < this.length; i++) {
              const charY = startY - (i * fontHeight);
              if (charY < -20 || charY > height + 20) continue;

              const lengthFade = 1 - (i / this.length);
              let alpha = lengthFade * this.opacity;

              let color;
              const isLeading = (i === 0);

              const distToMouse = Math.sqrt(Math.pow(gridX - mouse.x, 2) + Math.pow(charY - mouse.y, 2));
              let mouseGlow = 1.0;
              if (distToMouse < 80 && Date.now() - mouse.lastActive < 2000) {
                mouseGlow = (1 - (distToMouse / 80)) * 1.5 + 1.0;
              }

              let inRipple = false;
              ripples.forEach(ripple => {
                const distToRipple = Math.sqrt(Math.pow(gridX - ripple.x, 2) + Math.pow(charY - ripple.y, 2));
                const rippleDiff = Math.abs(distToRipple - ripple.radius);
                if (rippleDiff < ripple.thickness) {
                  inRipple = true;
                  alpha = Math.max(alpha, (1 - (rippleDiff / ripple.thickness)) * 1.0);
                }
              });

              if (inRipple) {
                color = `rgba(0, 235, 255, ${alpha})`;
                ctx.shadowColor = '#00e1ff';
                ctx.shadowBlur = 15;
              } else if (isLeading) {
                color = `rgba(255, 255, 255, ${alpha * mouseGlow})`;
                ctx.shadowColor = colorMode === 'red' ? '#ff3333' : (colorMode === 'blue' ? '#3399ff' : (colorMode === 'gold' ? '#ffe600' : '#ffffff'));
                ctx.shadowBlur = 10;
              } else {
                ctx.shadowBlur = this.glows[i] ? 8 : 0;
                
                if (colorMode === 'red') {
                  ctx.shadowColor = '#ff0000';
                  color = isLeading ? '#ffffff' : (this.glows[i] ? `rgba(255, 100, 100, ${alpha * mouseGlow})` : `rgba(200, 0, 0, ${alpha * mouseGlow})`);
                } else if (colorMode === 'blue') {
                  ctx.shadowColor = '#0055ff';
                  color = isLeading ? '#ffffff' : (this.glows[i] ? `rgba(150, 200, 255, ${alpha * mouseGlow})` : `rgba(0, 50, 220, ${alpha * mouseGlow})`);
                } else if (colorMode === 'gold') {
                  ctx.shadowColor = '#ffaa00';
                  color = isLeading ? '#ffffff' : (this.glows[i] ? `rgba(255, 230, 150, ${alpha * mouseGlow})` : `rgba(212, 140, 0, ${alpha * mouseGlow})`);
                } else {
                  ctx.shadowColor = '#00ff00';
                  color = this.glows[i] ? `rgba(180, 255, 180, ${alpha * mouseGlow})` : `rgba(0, 200, 0, ${alpha * mouseGlow})`;
                }
              }

              ctx.fillStyle = color;

              let finalX = gridX;
              if (warpEffect) {
                finalX += Math.sin((charY / 50) + (Date.now() / 200)) * 25;
              }

              ctx.fillText(this.chars[i], finalX, charY);
              ctx.shadowBlur = 0;
            }
          }
        }

        function initializeColumns() {
          columns = [];
          const colWidth = 18;
          const colCount = Math.floor(width / colWidth) + 1;
          for (let i = 0; i < colCount; i++) {
            columns.push(new Drop(i * colWidth));
          }
        }

        initializeColumns();

        window.addEventListener('mousemove', (e) => {
          mouse.x = e.clientX;
          mouse.y = e.clientY;
          mouse.lastActive = Date.now();
        });

        window.addEventListener('click', (e) => {
          if (!isDecrypted) return;
          const target = e.target as HTMLElement;
          if (!target.closest('.terminal-container') && !target.closest('#dance-overlay')) {
            ripples.push({
              x: e.clientX,
              y: e.clientY,
              radius: 0,
              maxRadius: Math.max(width, height) * 0.4,
              speed: 12,
              thickness: 25
            });
          }
        });

        window.addEventListener('keydown', (e) => {
          if (!isDecrypted) return;
          const target = e.target as HTMLElement;
          if (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA') {
            return;
          }

          if (e.key.length === 1) {
            const randomX = Math.random() * width;
            const newDrop = new Drop(randomX);
            newDrop.speed = 8;
            newDrop.opacity = 1.0;
            newDrop.chars[0] = e.key;
            newDrop.glows[0] = true;
            columns.push(newDrop);
            
            if (columns.length > 300) {
              columns.shift();
            }
          }

          handleSecretPhrase(e.key);
        });

        let keyBuffer = '';
        const danceOverlay = document.getElementById('dance-overlay') as HTMLElement;
        const overlayText = document.getElementById('overlay-text') as HTMLElement;
        const overlaySubtext = document.getElementById('overlay-subtext') as HTMLElement;
        const terminalContainer = document.querySelector('.terminal-container') as HTMLElement;

        const phrases = [
          { key: "red pill", action: triggerRedPill },
          { key: "blue pill", action: triggerBluePill },
          { key: "white rabbit", action: triggerWhiteRabbit },
          { key: "neo", action: triggerNeoGold },
          { key: "morpheus", action: triggerMorpheus },
          { key: "there is no spoon", action: triggerSpoonWarp },
          { key: "knock knock", action: triggerWhiteRabbit },
          { key: "zion", action: triggerZionCore }
        ];

        function handleSecretPhrase(key: string) {
          if (key.length === 1) {
            keyBuffer += key.toLowerCase();
            if (keyBuffer.length > 50) {
              keyBuffer = keyBuffer.slice(-50);
            }

            for (const item of phrases) {
              if (keyBuffer.endsWith(item.key)) {
                item.action();
                keyBuffer = '';
                break;
              }
            }
          }
        }

        function showOverlay(title: string, subtext: string, cssClass = '', duration = 8000) {
          document.body.classList.add('dance-active'); // Fade matrix back in
          danceOverlay.className = cssClass;
          overlayText.textContent = title;
          overlayText.setAttribute('data-text', title);
          overlaySubtext.textContent = subtext;
          
          danceOverlay.classList.remove('hidden');
          
          setTimeout(() => {
            danceOverlay.classList.add('hidden');
          }, duration);
        }

        function triggerRedPill() {
          colorMode = 'red';
          if (terminalContainer) terminalContainer.className = 'terminal-container red-state';
          showOverlay(
            "SYSTEM COMPROMISED: RED PILL PATH",
            "You take the red pill. You stay in Wonderland, and I show you how deep the rabbit hole goes.",
            "red-overlay"
          );
          setTimeout(() => { resetMatrixDances(); }, 10000);
        }

        function triggerBluePill() {
          colorMode = 'blue';
          if (terminalContainer) terminalContainer.className = 'terminal-container blue-state';
          showOverlay(
            "SYSTEM RESTORED: BLUE PILL PATH",
            "You take the blue pill. The story ends, you wake up in your bed and believe whatever you want to believe.",
            "blue-overlay"
          );
          setTimeout(() => { resetMatrixDances(); }, 10000);
        }

        function triggerNeoGold() {
          colorMode = 'gold';
          bulletTime = true;
          if (terminalContainer) terminalContainer.className = 'terminal-container gold-state';
          showOverlay(
            "COGNITIVE OVERCLOCK: CHOSEN_ONE_MODE",
            "Establishing bypass... 'There is a difference between knowing the path and walking the path.' Bullet time enabled.",
            "gold-overlay",
            6000
          );
          setTimeout(() => { resetMatrixDances(); }, 8000);
        }

        function triggerMorpheus() {
          colorMode = 'gold';
          showOverlay(
            "AUTHORIZED BY MORPHEUS",
            "\"No one can be told what the Matrix is. You have to see it for yourself.\" High-resonance stream activated.",
            "gold-overlay",
            6000
          );
          setTimeout(() => { resetMatrixDances(); }, 8000);
        }

        function triggerSpoonWarp() {
          warpEffect = true;
          showOverlay(
            "PERCEPTUAL ERROR: WAVE_WARP_ACTIVE",
            "\"Do not try and bend the spoon, that's impossible. Instead, only try to realize the truth... There is no spoon.\"",
            "",
            7000
          );
          setTimeout(() => { resetMatrixDances(); }, 12000);
        }

        function triggerZionCore() {
          zionFrenzy = true;
          showOverlay(
            "ZION CORE INITIALIZED",
            "Decentralized mainframe overload! Operational rain capacity amplified 350%.",
            "",
            6000
          );
          setTimeout(() => { resetMatrixDances(); }, 8000);
        }

        function triggerWhiteRabbit() {
          document.body.classList.add('dance-active'); // Fade matrix back in
          bulletTime = true;
          colorMode = 'green';
          
          danceOverlay.className = '';
          danceOverlay.classList.remove('hidden');
          overlayText.textContent = '';
          overlaySubtext.textContent = '';

          const dialogue = [
            "Wake up, Neo...",
            "The Matrix has you...",
            "Follow the white rabbit.",
            "Knock, knock."
          ];

          let lineIdx = 0;
          let charIdx = 0;
          let currentString = '';
          
          function typeWriter() {
            if (lineIdx < dialogue.length) {
              const targetLine = dialogue[lineIdx];
              if (charIdx < targetLine.length) {
                currentString += targetLine[charIdx];
                overlayText.textContent = currentString;
                charIdx++;
                setTimeout(typeWriter, 110);
              } else {
                lineIdx++;
                charIdx = 0;
                currentString = '';
                setTimeout(() => {
                  overlayText.textContent = '';
                  typeWriter();
                }, 1200);
              }
            } else {
              danceOverlay.classList.add('hidden');
              resetMatrixDances();
              
              ripples.push({
                x: width / 2,
                y: height / 2,
                radius: 0,
                maxRadius: Math.max(width, height) * 0.9,
                speed: 18,
                thickness: 50
              });
            }
          }

          typeWriter();
        }

        function resetMatrixDances() {
          colorMode = 'green';
          bulletTime = false;
          warpEffect = false;
          zionFrenzy = false;
          if (terminalContainer) terminalContainer.className = 'terminal-container';
          
          // Let the visual finish, then fade the matrix out completely again
          setTimeout(() => {
            document.body.classList.remove('dance-active');
          }, 3500);
        }

        function animate() {
          const currentWidth = getWidth();
          const currentHeight = getHeight();
          
          if (width !== currentWidth || height !== currentHeight) {
            width = canvas.width = currentWidth;
            height = canvas.height = currentHeight;
            initializeColumns();
          }

          ctx.fillStyle = 'rgba(0, 0, 0, 0.08)';
          ctx.fillRect(0, 0, width, height);

          columns.forEach(col => {
            col.update();
            col.draw();
          });

          ripples = ripples.filter(ripple => {
            ripple.radius += ripple.speed;
            return ripple.radius < ripple.maxRadius;
          });

          requestAnimationFrame(animate);
        }

        animate();

        // ---------------------------------------------------------------------
        // 3. Simple Handler to Hook Intro Click
        // ---------------------------------------------------------------------
        const triggerButton = document.getElementById('intro-gate');
        if (triggerButton) {
          triggerButton.addEventListener('click', () => {
            decryptConstruct();
          });
        }
      }

      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        startMatrixConstruct();
      } else {
        window.addEventListener('load', startMatrixConstruct);
      }
    </script>
  </body>
</html>